<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sports.sales.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.sports.sales.entity.SysUser">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="role" property="role"/>
        <result column="customer_code" property="customerCode"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT id, username, password, role, customer_code, status, create_time, update_time
        FROM sys_user
        WHERE username = #{username} AND status = 1
    </select>

    <select id="countByUsername" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE username = #{username}
    </select>

    <insert id="insert" parameterType="com.sports.sales.entity.SysUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (username, password, role, customer_code, status)
        VALUES (#{username}, #{password}, #{role}, #{customerCode}, #{status})
    </insert>
</mapper>
